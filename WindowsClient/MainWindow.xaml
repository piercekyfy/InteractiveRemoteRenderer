<Window x:Class="WindowsClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WindowsClient"
        mc:Ignorable="d"
        Title="MainWindow" Height="432" Width="768" Background="Black">
    <Grid>
        <Image x:Name="VideoIn" Stretch="Fill" Focusable="True"/>

        <StackPanel x:Name="watermark" HorizontalAlignment="Center" VerticalAlignment="Center"
            IsHitTestVisible="False">
            <TextBlock Text="IRR" FontSize="120" Foreground="#22ffffff" 
               HorizontalAlignment="Center"
               FontWeight="Bold" FontFamily="Segoe UI"/>
            <TextBlock Text="Interactive Remote Renderer" FontSize="18" Foreground="#18ffffff"
               HorizontalAlignment="Center" FontFamily="Segoe UI Light"/>
        </StackPanel>

        <Rectangle x:Name="statusSquare" Width="15" Height="15" Fill="Red" 
                   HorizontalAlignment="Left" VerticalAlignment="Top" 
                   Margin="10 10 0 0" RadiusX="15" RadiusY="15"/>

        <Border x:Name="controlPanel" HorizontalAlignment="Right" VerticalAlignment="Top" 
                Margin="0 10 10 0" CornerRadius="8" Padding="12 8"
                Background="#AA1e1e1e" Opacity="0">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="1"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Border.MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                            To="1" Duration="0:0:0.2"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="Border.MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                            To="0" Duration="0:0:0.2"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>

            <StackPanel Orientation="Horizontal">
                <Button x:Name="btnMinimizePanel" Content="◀" Width="16" Height="16"
                        Background="Transparent" Foreground="#888" BorderThickness="0"
                        FontSize="10" Padding="0" Margin="0 0 8 0" VerticalAlignment="Center"
                        Click="btnMinimizePanel_Click"/>

                <StackPanel x:Name="panelContent" Orientation="Horizontal">
                    <StackPanel Margin="0 0 12 0">
                        <TextBlock Text="Host" Foreground="#888" FontSize="10" Margin="0 0 0 2"/>
                        <TextBox x:Name="txtHost" Width="120" Height="26"
                                 Background="#333" Foreground="White"
                                 BorderBrush="#555" BorderThickness="1"
                                 Padding="4 2" CaretBrush="White"/>
                    </StackPanel>
                    <StackPanel Margin="0 0 12 0">
                        <TextBlock Text="Port" Foreground="#888" FontSize="10" Margin="0 0 0 2"/>
                        <TextBox x:Name="txtPort" Width="70" Height="26"
                                 Background="#333" Foreground="White"
                                 BorderBrush="#555" BorderThickness="1"
                                 Padding="4 2" CaretBrush="White"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                        <Button x:Name="btnConnect" Content="Connect" Width="80" Height="26"
                                Margin="0 0 6 0" Click="btnConnect_Click"
                                Background="#2a7a2a" Foreground="White" BorderThickness="0"/>
                        <Button x:Name="btnDisconnect" Content="Disconnect" Width="90" Height="26"
                                Click="btnDisconnect_Click"
                                Background="#7a2a2a" Foreground="White" BorderThickness="0"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border x:Name="hintBoxConnect" HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0 75 290 0" CornerRadius="6" Padding="10 6"
                Background="#AA1e1e1e">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="👆 Hover here to connect" Foreground="White" FontSize="12"/>
            </StackPanel>
        </Border>

        <Border x:Name="hintBoxStatus" HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="0 30 10 0" CornerRadius="6" Padding="10 6"
                Background="#AA1e1e1e">
            <StackPanel Orientation="Vertical" Margin="5 0 0 0">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="12" Height="12" Fill="Red"/>
                    <TextBlock Text=" = Disconnected" Foreground="White" FontSize="12"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="12" Height="12" Fill="Yellow"/>
                    <TextBlock Text=" = Connecting" Foreground="White" FontSize="12"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="12" Height="12" Fill="Green"/>
                    <TextBlock Text=" = Connected" Foreground="White" FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>